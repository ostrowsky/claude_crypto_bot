# =============================================
# PolyBot v2.0 «Deep Signal» — Configuration
# =============================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USERS=123456789,987654321

# --- Polymarket ---
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# --- FRED (макро-данные: CPI, ставки ФРС, GDP) ---
# Получить бесплатно: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- AI / LLM ---
# Провайдер: openai | anthropic | deepseek
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Paper Trading ---
PAPER_TRADING=true
PAPER_BALANCE=10000

# --- Risk Management ---
MAX_POSITION_SIZE=100
MAX_DAILY_LOSS=50
MAX_OPEN_POSITIONS=10
KILL_SWITCH_LOSS_PCT=0.15
